{% liquid
  assign image_height = block.settings.image.aspect_ratio
  assign image_height_mobile = block.settings.image.aspect_ratio

  if block.settings.card_height == 'auto'
    assign image_height = '100'
  elsif block.settings.card_height == 'very_small'
    assign image_height = '200'
  elsif block.settings.card_height == 'small'
    assign image_height = '300'
  elsif block.settings.card_height == 'medium'
    assign image_height = '400'
  elsif block.settings.card_height == 'large'
    assign image_height = '500'
  endif

  if block.settings.card_height_mobile == 'auto'
    assign image_height_mobile = '100'
  elsif block.settings.card_height_mobile == 'very_small'
    assign image_height_mobile = '200'
  elsif block.settings.card_height_mobile == 'small'
    assign image_height_mobile = '300'
  elsif block.settings.card_height_mobile == 'medium'
    assign image_height_mobile = '400'
  elsif block.settings.card_height_mobile == 'large'
    assign image_height_mobile = '500'
  endif
%}

<div
  class="
    image-card card color-{{ block.settings.color_scheme }}
    {%- if block.settings.show_on_display == 'desktop_only' %} mobile-hide{% endif -%}
    {%- if block.settings.show_on_display == 'mobile_only' %} desktop-hide{% endif -%}
    {%- if block.settings.additional_class != blank %} {{ block.settings.additional_class }}{% endif -%}
    {%- if block.settings.card_link != blank %} stretched-link{% endif -%}
  "
  style="
    --image-height: {{ image_height }}px;
    --image-height-mobile: {{ image_height_mobile }}px;
    --padding-horizontal: {{ block.settings.padding_horizontal }}px;
    --padding-vertical: {{ block.settings.padding_vertical }}px;
    --margin-top: {{ block.settings.margin_top }}px;
    --margin-bottom: {{ block.settings.margin_bottom }}px;
    --justify: {{ block.settings.layout_justify }};
    --align_items: {{ block.settings.layout_align_items }};
  "
  {{ block.shopify_attributes }}
  {% if request.visual_preview_mode %}
    data-visual-preview-mode
  {% endif %}
>
  {% if block.settings.card_link != blank %}
    <a href="{{ block.settings.card_link }}" class="stretched-link__overlay"></a>
  {% endif %}

  <div class="image-card__image">
    <div
      class="image-card__image-filter"
      style="
        --color: {{ block.settings.image_filter_color }};
        --opacity: {{ block.settings.image_filter_opacity }}
      "
    ></div>

    {% if block.settings.image != blank %}
      {% liquid
        assign image_width = '100vw'

        assign sizes = '(min-width: 750px) ' | append: image_width | append: ', ' | append: image_width
        assign widths = '832, 1200, 1600, 1920, 2560, 3840'
      %}

      {{
        block.settings.image
        | image_url: width: 3840
        | image_tag:
          width: block.settings.image.width,
          widths: widths,
          height: block.settings.image.height,
          alt: block.settings.image.alt,
          sizes: sizes
      }}
    {% else %}
      {% assign default_alt = 'placeholder.placeholder_banner_alt' | t %}
      <img
        src="{{ 'placeholder-banner.jpg'  | asset_img_url: 'x1200' }}"
        alt="{{ default_alt }}"
        width="1000"
        height="auto"
        class="placeholder-image"
        loading="lazy"
      >
    {% endif %}
  </div>

  <div class="image-card__content-wrapper">
    <div class="image-card__content">
      {% content_for 'blocks' %}
    </div>
  </div>
</div>

{% stylesheet %}
  .image-card {
    position: relative;
    overflow: hidden;
    margin-top: var(--margin-top);
    margin-bottom: var(--margin-bottom);
    text-decoration: none;
    color: var(--color-foreground);
    width: 100%;
    height: 100%;
    display: block;

    &.card {
      padding: 0;
    }
  }

  shopify-visual-preview-block-list .image-card[data-visual-preview-mode] {
    width: 350px;
  }

  .image-card__image-filter {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: var(--color);
    opacity: calc(var(--opacity) / 100);
    z-index: 1;
  }

  .image-card__image {
    position: absolute;
    width: 100%;
    height: 100%;

    img,
    .placeholder-image {
      height: 100%;
      width: 100%;
      object-fit: cover;
      object-position: center center;
      border-radius: 0;
      overflow: hidden;
      position: relative;
    }
  }

  .image-card__content-wrapper {
    position: relative;
    width: 100%;
    z-index: 2;
    padding: var(--card-padding);
    height: 100%;

    .image-card__content {
      width: 100%;
      min-height: var(--image-height-mobile);
      height: 100%;
      display: flex;
      flex-direction: column;
      gap: var(--gap-xxs);
      justify-content: var(--justify);
      align-items: var(--align_items);
    }
  }

  /* L'overlay passe au-dessus du filtre */
  .image-card .stretched-link__overlay {
    z-index: 2;
  }
  /* Le content-wrapper reste visuellement au-dessus, 
   mais transparent aux clics */
  .image-card.stretched-link .image-card__content-wrapper {
    z-index: 3;
    pointer-events: none;
  }
  /* Les éléments interactifs récupèrent les clics */
  .image-card.stretched-link .image-card__content-wrapper a,
  .image-card.stretched-link .image-card__content-wrapper button,
  .image-card.stretched-link .image-card__content-wrapper input,
  .image-card.stretched-link .image-card__content-wrapper select,
  .image-card.stretched-link .image-card__content-wrapper summary {
    pointer-events: auto;
  }

  @media (width > 750px) {
    .image-card__content {
      padding: var(--padding-vertical) var(--padding-horizontal);
    }

    .image-card__content-wrapper .image-card__content {
      min-height: var(--image-height);
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:image_card",
  "tag": null,
  "blocks": [
    {
      "type": "@theme"
    },
    {
      "type": "@app"
