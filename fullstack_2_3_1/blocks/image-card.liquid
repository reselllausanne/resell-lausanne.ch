        },
        {
          "value": "small",
          "label": "t:small"
        },
        {
          "value": "medium",
          "label": "t:medium"
        },
        {
          "value": "large",
          "label": "t:large"
        }
      ],
      "default": "auto"
    },
    {
      "type": "select",
      "id": "card_height_mobile",
      "label": "t:card_height_mobile",
      "options": [
        {
          "value": "auto",
          "label": "t:auto"
        },
        {
          "value": "very_small",
          "label": "t:very_small"
        },
        {
          "value": "small",
          "label": "t:small"
        },
        {
          "value": "medium",
          "label": "t:medium"
        },
        {
          "value": "large",
          "label": "t:large"
        }
